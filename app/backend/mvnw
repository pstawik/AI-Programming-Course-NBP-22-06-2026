# -----------------------------------------------------------------------
# Apache Maven Wrapper startup script (Spring Boot Initializr style), v3.3.2
# -----------------------------------------------------------------------

set -e

# Find the project base dir, i.e. the closest directory that contains a pom.xml
# file or a .mvn directory.
find_maven_basedir() {
  if [ -z "$1" ]
  then
    echo "Path not specified to find_maven_basedir"
    return 1
  fi

  basedir="$1"
  wdir="$1"
  while [ "$wdir" != '/' ] ; do
    if [ -d "$wdir"/.mvn ] ; then
      basedir=$wdir
      break
    fi
    # workaround for JBEAP-8937 (on Solaris 10/Sparc)
    if [ -d "${wdir}" ]; then
      wdir=$(cd "$wdir/.."; pwd)
    fi
    # end of workaround
  done
  printf '%s' "$(cd "$basedir"; pwd)"
}

# concatenates all lines of a file
concat_lines() {
  if [ -f "$1" ]; then
    echo "$(tr -s '\n' ' ' < "$1")"
  fi
}

BASE_DIR=$(find_maven_basedir "$(dirname "$0")")
export BASE_DIR

MAVEN_PROJECTBASEDIR=${MAVEN_BASEDIR:-"$BASE_DIR"}
export MAVEN_PROJECTBASEDIR

WRAPPER_JAR="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar"
WRAPPER_LAUNCHER=org.apache.maven.wrapper.MavenWrapperMain
WRAPPER_URL="https://repo.maven.apache.org/maven2/org/apache/maven/wrapper/maven-wrapper/3.3.2/maven-wrapper-3.3.2.jar"

# Read wrapperUrl from maven-wrapper.properties if it exists
if [ -r "$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.properties" ]; then
  for p in $(grep -E "^\s*wrapperUrl\s*=" "$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.properties"); do
    p=$(echo "$p" | tr -d ' ')
    if echo "$p" | grep -q "^wrapperUrl="; then
      WRAPPER_URL=$(echo "$p" | cut -d= -f2-)
    fi
  done
fi

# Download wrapper jar if missing
if [ ! -e "$WRAPPER_JAR" ]; then
  echo "Downloading Maven Wrapper jar..."
  if [ -x "$(command -v curl)" ]; then
    curl -fsSL -o "$WRAPPER_JAR" "$WRAPPER_URL"
  elif [ -x "$(command -v wget)" ]; then
    wget -q -O "$WRAPPER_JAR" "$WRAPPER_URL"
  else
    # Use Java to download
    java -classpath "" \
         -Djar.url="$WRAPPER_URL" \
         -Djar.output="$WRAPPER_JAR" \
         -e 'import java.net.*; import java.nio.file.*; new URL(System.getProperty("jar.url")).openStream().transferTo(Files.newOutputStream(Path.of(System.getProperty("jar.output"))))' \
         || echo "WARNING: Could not download maven-wrapper.jar automatically."
  fi
fi

JAVA_CMD="java"
if [ -n "$JAVA_HOME" ]; then
  JAVA_CMD="$JAVA_HOME/bin/java"
fi

if [ -z "$MAVEN_OPTS" ]; then
  MAVEN_OPTS="-Xmx512m -Dmaven.compiler.release=21"
fi

exec "$JAVA_CMD" \
  $MAVEN_OPTS \
  "-Dmaven.multiModuleProjectDirectory=$MAVEN_PROJECTBASEDIR" \
  -classpath "$WRAPPER_JAR" \
  "$WRAPPER_LAUNCHER" "$@"
