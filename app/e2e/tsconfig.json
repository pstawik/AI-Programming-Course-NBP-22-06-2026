{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020", "dom"],
    "strict": true,
    "esModuleInterop": true,
    "outDir": "dist",
    "rootDir": ".",
    "skipLibCheck": true,
    "moduleResolution": "node"
  },
  "include": ["tests/**/*.ts", "fixtures/**/*.ts", "playwright.config.ts"],
  "exclude": ["node_modules", "dist"]
}
